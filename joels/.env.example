# .env.example - Copy to .env and fill in your values

# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=your-super-secret-key-change-this

# Database (SQLite for development, PostgreSQL for production)
DATABASE_URL=sqlite:///giztech.db
# DATABASE_URL=postgresql://user:password@localhost/giztech

# Redis (for caching and rate limiting)
REDIS_URL=redis://localhost:6379/0

# Owner Authentication
OWNER_PASSWORD=your-secure-password-change-this

# Business Information
BUSINESS_NAME=GIZ-tech
WHATSAPP_NUMBER=265983142415
BUSINESS_EMAIL=joelkaudzu9@gmail.com

# Email Configuration (for notifications)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=joelkaudzu9@gmail.com
MAIL_PASSWORD=mfsd inyg zkjw jhgi
MAIL_DEFAULT_SENDER=noreply@giztech.com

# WhatsApp Business API (optional)
WHATSAPP_API_KEY=your-whatsapp-api-key

# SEO
SITE_URL=https://your-domain.com
DEFAULT_META_TITLE=GIZ-tech - Premium Tech Products
DEFAULT_META_DESCRIPTION=Discover premium tech products at GIZ-tech

# Analytics
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X
FACEBOOK_PIXEL_ID=XXXXXXXXX

# File Uploads
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=app/static/uploads

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/giztech.log

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_CACHING=true
ENABLE_RATE_LIMITING=true